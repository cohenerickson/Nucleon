      "isDeleted": false,
      "boundElements": [
        {
          "id": "Y5qgeU6kT_MjenLQRDs38",
          "type": "arrow"
        }
      ],
      "updated": 1770993133712,
      "link": null,
      "locked": false,
      "text": "This service worker will also handle any and all PWA functions of the app, including hosting an offline page for /app in\nthe event that a network connection is interupted. The PWA can be installed as an \"app\" and uses the Window Controls\nOverlay API where available.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "This service worker will also handle any and all PWA functions of the app, including hosting an offline page for /app in\nthe event that a network connection is interupted. The PWA can be installed as an \"app\" and uses the Window Controls\nOverlay API where available.",
      "autoResize": true,
      "lineHeight": 1.25
    },
