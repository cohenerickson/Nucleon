      "boundElements": [],
      "updated": 1770992191325,
      "link": null,
      "locked": false,
      "text": "External webpages get proxied through either ScramJet or Ultraviolet.\nThe browser UI displays a protocol of either scram:// or uv:// depending\non which proxy the user has selected as default. This functionality lets\nthe user change the proxy for certain websites if compatibility issues\narise.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "External webpages get proxied through either ScramJet or Ultraviolet.\nThe browser UI displays a protocol of either scram:// or uv:// depending\non which proxy the user has selected as default. This functionality lets\nthe user change the proxy for certain websites if compatibility issues\narise.",
      "autoResize": true,
      "lineHeight": 1.25
    },
