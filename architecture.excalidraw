    {
      "id": "1OZ9TabCLUbP1rwK2HNnG",
      "type": "text",
      "x": 317.11438769064836,
      "y": 51.22969899515016,
      "width": 937.4393310546875,
      "height": 60,
      "angle": 0,
      "strokeColor": "#1e1e1e",
